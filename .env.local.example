# ─── AI Provider ────────────────────────────────────────────────────────────
# Plug in your OpenAI key to enable real AI generation.
# See README.md → "Plugging in OpenAI" for exact setup instructions.
OPENAI_API_KEY=

# Model to use (gpt-4o recommended for best website copy quality)
OPENAI_MODEL=gpt-4o

# ─── Auth (required in production; Auth.js will error without it) ────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=
# NEXTAUTH_SECRET=   # legacy alias; use same value as AUTH_SECRET if set

# ─── Landing contact form (SMTP — use Zoho *outgoing* settings, not IMAP) ────
# Zoho: smtppro.zoho.com, port 465 (SSL) or 587 (TLS). Use an app password if 2FA is on.
# SMTP_HOST=smtppro.zoho.com
# SMTP_PORT=465
# SMTP_USER=you@yourdomain.com
# SMTP_PASS=
# Where to receive lead notifications. If your domain uses Cloudflare *Email Routing*
# (MX on Cloudflare), do NOT set this to the same forwarded address—use a direct inbox
# (e.g. Gmail) or Cloudflare may bounce with 550 "Cannot forward emails that are not authenticated".
# LEAD_TO_EMAIL=yourpersonal@gmail.com
# Optional: From address (defaults to SMTP_USER; must be allowed by Zoho)
# LEAD_FROM_EMAIL=you@yourdomain.com
# LEAD_FROM_NAME=Website contact form

# ─── Anti-spam (Cloudflare Turnstile + Upstash rate limits) ─────────────────
# Create a Turnstile widget at https://dash.cloudflare.com/ → Turnstile
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# Rate limits use the same Redis as KV/Upstash (UPSTASH_REDIS_* / KV_REST_*)
# Landing-page favicon (set in /admin) is stored in the same Redis under settings:landingBranding

# ─── Google Places (optional — “Import from Google” for reviews in admin) ────
# Enable “Places API (New)” in Google Cloud → Credentials. Server-side only.
# GOOGLE_PLACES_API_KEY=
# (alias) GOOGLE_MAPS_API_KEY=

# ─── App Config ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Storage (future) ────────────────────────────────────────────────────────
# Swap the file-based store for Postgres/Supabase when ready.
# DATABASE_URL=postgresql://...
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=
